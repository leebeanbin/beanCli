# ─── Application ─────────────────────────────────
APP_ENV=dev
APP_PORT=3100

# ─── PostgreSQL ──────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=tfsdc
POSTGRES_PORT=15432
DATABASE_URL=postgres://postgres:postgres@localhost:15432/tfsdc

# ─── Kafka ───────────────────────────────────────
KAFKA_PORT=19092
KAFKA_INTERNAL_PORT=39092
KAFKA_BROKER=localhost:19092
KAFKA_GROUP_ID=tfsdc-projector
KAFKA_UI_PORT=18080
KAFKAJS_NO_PARTITIONER_WARNING=1

# ─── Entity ID ───────────────────────────────────
ENTITY_ID_PLAIN_ENABLED=true

# ─── JWT ─────────────────────────────────────────
JWT_SECRET=dev-jwt-secret-change-in-prod
JWT_EXPIRY_SECONDS=3600

# ─── Sidecar ─────────────────────────────────────
SIDECAR_MODE=MANAGED
SIDECAR_RATE_LIMIT_RPS=100

# ─── TUI CLI ─────────────────────────────────────
API_URL=http://localhost:3100
WS_URL=ws://localhost:3100/ws
# API_TOKEN=             # set if auth is required

# ─── Web Console (Next.js) ────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3100

# ─── AI (beanllm sidecar) ────────────────────────
BEANLLM_SIDECAR_URL=http://localhost:3200
BEANLLM_MODEL=qwen2.5:0.5b
BEANLLM_PATH=../beanllm
BEANLLM_PORT=3200
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# OLLAMA_HOST=http://localhost:11434
