{
  "name": "tfsdc",
  "version": "0.1.2",
  "private": true,
  "description": "Terminal-First Streaming Data Console — Modern TUI AI Database Manager",
  "packageManager": "pnpm@10.28.1",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:migrate": "bash packages/sql/migrations/run_migrations.sh",
    "dev:all": "bash scripts/dev-start.sh",
    "dev:api": "turbo run dev --filter=@tfsdc/api",
    "dev:projector": "turbo run dev --filter=@tfsdc/projector",
    "dev:cli": "node --env-file=.env --watch --import tsx apps/cli/src/index.ts",
    "dev:cli:ink": "node --env-file=.env --watch --import tsx/esm apps/cli/src/index-ink.tsx",
    "dev:cli:ink:filter": "turbo run dev:ink --filter=@tfsdc/cli",
    "dev:recovery": "turbo run dev --filter=@tfsdc/recovery-worker",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:reset": "docker compose down -v && docker compose up -d",
    "docker:wait": "bash scripts/wait-for-services.sh",
    "data:quality": "bash scripts/data-quality-report.sh",
    "data:quality:gate": "bash scripts/data-quality-gate.sh",
    "dev:stop": "bash scripts/dev-stop.sh",
    "setup": "cp -n .env.example .env 2>/dev/null; pnpm install; pnpm docker:up; pnpm docker:wait; echo '✅ Ready! Run: pnpm dev:all'"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.0",
    "eslint": "^10.0.0",
    "jest": "^30.2.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
    "turbo": "^2.8.10",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0"
  }
}
